# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# IDE / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local test / cache artifacts
.pytest_cache/
.mypy_cache/
.cache/

# Raw and processed data (keep lightweight placeholders / docs only)
data/raw/*
!data/raw/.gitkeep
!data/raw/README.md

data/processed/*
!data/processed/.gitkeep
!data/processed/README.md

# Optional local output files that you may not want to track
